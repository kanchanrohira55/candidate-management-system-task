{
  "name": "fresh-shifts-candidate-management",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "db:deploy": "node backend/node_modules/prisma/build/index.js migrate deploy --schema backend/prisma/schema.prisma",
    "prisma:generate": "node backend/node_modules/prisma/build/index.js generate --schema backend/prisma/schema.prisma",
    "build": "npm run prisma:generate && npm --workspace frontend run build",
    "vercel-build": "npm run db:deploy && npm run build",
    "test": "npm --workspace backend test"
  }
}
